// 20. STRING ESCAPE SEQUENCES
// ══════════════════════════════════════════════════════════════

// All escape sequences
tab_sep     := "col1\tcol2\tcol3"          // horizontal tab
newline_sep := "line 1\nline 2\nline 3"    // newline
crlf        := "windows\r\nline ending"    // CRLF
backslash   := "C:\\Users\\razen\\notes"   // literal \
quoted      := "she said \"hello\""        // literal "
single_q    := 'it\'s a char'              // literal ' in char literal
null_byte   := "\0"                        // null terminator
hex_A       := "\x41"                      // hex byte: 'A'
hex_null    := "\x00"                      // hex byte: null
smiley      := "\u{1F600}"                 // unicode: 😀
heart       := "\u{2764}"                  // unicode: ❤
music_note  := "\u{1F3B5}"                // unicode: 🎵

// Raw strings — no escape processing
raw_path    := r"C:\Users\razen\notes.txt"     // backslash is literal
raw_regex   := r"\d{3}-\d{3}-\d{4}"           // regex pattern
raw_latex   := r"\frac{a}{b} + \sqrt{c^2}"    // LaTeX
raw_windows := r"\\server\share\file.txt"      // UNC path

// Multiline with \n
multiline_a := "first line\nsecond line\nthird line"

// Multiline string literal (newline in source)
multiline_b := "first line
second line
third line"

// String builder for dynamic construction
mut b := string_builder()
b.append("Hello")
b.append(", ")
b.append("Razen!\n")
b.append("\t→ version: 1.0")
result_str := b.to_string()
// "Hello, Razen!\n\t→ version: 1.0"
